{
  "name": "@openchamber/control-plane",
  "version": "1.16.2",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"./src/**/*.ts\" \"./test/**/*.ts\" \"./vitest.config.ts\" --config ../../eslint.config.js",
    "types": "wrangler types",
    "types:check": "wrangler types --check",
    "check:startup": "wrangler check startup",
    "check": "bun run types:check && bun run type-check && bun run lint && bun run test && bun run check:startup"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "typescript": "~5.9.0",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
